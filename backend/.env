# ═══════════════════════════════════════════════════════════
# Windows Native Setup — copy this to backend\.env or set as
# environment variables before running the backend locally.
# ═══════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────
# CHANGE these values to match your local PostgreSQL install.
# Host = localhost  (instead of Docker's "db" container)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/workorders

# ── Security ──────────────────────────────────────────────
# Change this to a long random string in production.
SECRET_KEY=change-me-to-a-random-secret-string-at-least-32-chars

# ── App ───────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=480
MAX_UPLOAD_SIZE_MB=10

# ── Upload directory ──────────────────────────────────────
# Relative to the backend/ directory.  On Windows this
# resolves to .\uploads\ under the backend folder.
# If you prefer an absolute path, use something like:
#   UPLOAD_DIR=C:/WorkOrderApp/uploads
UPLOAD_DIR=./uploads

# ── CORS ──────────────────────────────────────────────────
# Ports for the Vite dev server (5173 default, 3000 here).
CORS_ORIGINS=http://localhost:5173,http://localhost:4170
